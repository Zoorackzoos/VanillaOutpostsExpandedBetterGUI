<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Vanilla Expanded Outposts - Better GUI</name>
  <packageId>Zoorackzoos.Vanilla_Outposts_Expanded_Better_GUI</packageId>
  <author>Zoorackzoos</author>
  <!--
  TODO: make this URL go to the steam page, not the git repo
  -->
  <url>https://github.com/Zoorackzoos/VanillaOutpostsExpandedBetterGUI</url>
  <description>
Replaces the small dropdown menus for adding and removing pawns from
Vanilla Outposts Expanded outposts with a scrollable trade-screen style
dialog.

Select multiple pawns at once, see their top skills at a glance, and
use Select All / Deselect All for large colonies.

Requires: Vanilla Expanded Framework + Vanilla Outposts Expanded.
  </description>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <modDependencies>
    <!-- Vanilla Expanded Framework -->
    <li>
      <packageId>OskarPotocki.VanillaFactionsExpanded.Core</packageId>
      <displayName>Vanilla Expanded Framework</displayName>
      <steamWorkshopUrl>https://steamcommunity.com/sharedfiles/filedetails/?id=2023507013</steamWorkshopUrl>
    </li>
    <!-- Vanilla Outposts Expanded -->
    <li>
      <packageId>vanillaexpanded.outposts</packageId>
      <displayName>Vanilla Outposts Expanded</displayName>
      <steamWorkshopUrl>https://steamcommunity.com/sharedfiles/filedetails/?id=2688941031</steamWorkshopUrl>
    </li>
  </modDependencies>
  <loadAfter>
    <li>OskarPotocki.VanillaFactionsExpanded.Core</li>
    <li>vanillaexpanded.voe</li>
  </loadAfter>
</ModMetaData>
